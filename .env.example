# Copiá a .env y completá. NO commitear .env (ya está en .gitignore).
# En local podés dejar los defaults; en producción generá valores fuertes
# (idealmente desde AWS SSM/Secrets Manager, ver docs/02 §13.1).

# Perfiles de Docker Compose. "dev" levanta Jupyter (entorno de desarrollo).
# En producción dejalo VACÍO o quitá esta línea: el ETL corre por Airflow y no
# hace falta el server de Jupyter (el .env generado desde SSM no debe incluirlo).
COMPOSE_PROFILES=dev

POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow            # prod: openssl rand -hex 24
POSTGRES_DB=airflow

AIRFLOW_JWT_SECRET=change-me-in-prod # prod: openssl rand -hex 32
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin         # prod: valor fuerte

JUPYTER_TOKEN=                       # prod: token largo
GRAFANA_ADMIN_PASSWORD=admin         # prod: valor fuerte
