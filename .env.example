# Copiá a .env y completá. NO commitear .env (ya está en .gitignore).
# En local podés dejar los defaults; en producción generá valores fuertes
# (idealmente desde AWS SSM/Secrets Manager, ver docs/02 §13.1).

# Perfiles de Docker Compose. "dev" levanta Jupyter (entorno de desarrollo).
# En producción dejalo VACÍO o quitá esta línea: el ETL corre por Airflow y no
# hace falta el server de Jupyter (el .env generado desde SSM no debe incluirlo).
COMPOSE_PROFILES=dev

POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow            # prod: openssl rand -hex 24
POSTGRES_DB=airflow

AIRFLOW_JWT_SECRET=change-me-in-prod # prod: openssl rand -hex 32
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin         # prod: valor fuerte

JUPYTER_TOKEN=                       # prod: token largo
GRAFANA_ADMIN_PASSWORD=admin         # prod: valor fuerte

# --- Solo prod, solo si exponés Airflow por HTTPS con dominio propio (docs/02 §5.6) ---
# Dejalas SIN COMPLETAR (comentadas o vacías) en modo túnel-only: docker-compose.prod.yml
# ya cae a HTTP plano por el túnel SSH a 8082 sin esto. Completalas recién cuando corras
# certbot y tengas el dominio funcionando, con:
#   DOMAIN=$(terraform -chdir=infra/prod output -raw airflow_domain)
#   echo "AIRFLOW_DOMAIN=$DOMAIN" >> .env
#   echo "AIRFLOW_BASE_URL=https://$DOMAIN" >> .env
#   echo "AIRFLOW_EXECUTION_API_URL=https://$DOMAIN:8080/execution/" >> .env
#   echo "AIRFLOW_SSL_CERT=/opt/airflow/certs/live/$DOMAIN/fullchain.pem" >> .env
#   echo "AIRFLOW_SSL_KEY=/opt/airflow/certs/live/$DOMAIN/privkey.pem" >> .env
# AIRFLOW_DOMAIN=
# AIRFLOW_BASE_URL=
# AIRFLOW_EXECUTION_API_URL=
# AIRFLOW_SSL_CERT=
# AIRFLOW_SSL_KEY=
